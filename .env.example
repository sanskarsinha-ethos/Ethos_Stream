# .env.example
# Copy to .env and fill in values before running docker-compose

# ---- Supabase Configuration ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# ---- Database connection for the App (uses Supabase Pooler - port 6543) ----
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres
SPRING_DATASOURCE_USERNAME=postgres.your_project
SPRING_DATASOURCE_PASSWORD=your_db_password

# ---- Database connection for Flyway Migrations (direct connection - port 5432) ----
SPRING_FLYWAY_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:5432/postgres
SPRING_FLYWAY_USER=postgres.your_project
SPRING_FLYWAY_PASSWORD=your_db_password

# ---- AWS S3 Configuration ----
AWS_REGION=us-east-1
AWS_BUCKET=ethos-stream-videos
AWS_CLOUDFRONT_DOMAIN=https://your-cloudfront-id.cloudfront.net
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ---- Redis Configuration ----
# When running with docker-compose, this is typically 'redis'
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# ---- Server Port ----
PORT=8080
